# Copy this file to .env and set values appropriate to your environment.
# Never commit .env. Values below are configuration examples, not credentials.

# -----------------------------------------------------------------------------
# Application and logging (optional)
# -----------------------------------------------------------------------------
APP_ENV=development
LOG_LEVEL=INFO
LOG_FORMAT=json

# -----------------------------------------------------------------------------
# LLM (required for live Agent chat and RAG generation)
# OPENAI_API_KEY is required for live Agent chat and must be supplied privately. Use the provider/base URL/model that
# your account supports. Gemini uses its OpenAI-compatible endpoint.
# -----------------------------------------------------------------------------
# Required for live Agent chat; leave blank only for offline/unit checks.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_MODEL=gemini-3.1-flash-lite
LLM_PROVIDER=gemini_openai_compatible
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=2

# -----------------------------------------------------------------------------
# Qdrant and canonical retrieval configuration (required for retrieval)
# Local development defaults are embedded Qdrant. Docker Compose overrides this
# group to the internal Qdrant server; do not change the selected retrieval
# settings without an explicit retrieval decision.
# -----------------------------------------------------------------------------
QDRANT_MODE=local
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=labor_law_chunks
QDRANT_LOCAL_PATH=data/qdrant_local

EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=auto
EMBEDDING_USE_FP16=
EMBEDDING_BATCH_SIZE=4
EMBEDDING_MAX_LENGTH=1024
LONG_CHUNK_POLICY=error

DENSE_TOP_K=5
DENSE_MAX_TOP_K=10
RETRIEVAL_MODE=hybrid_underthesea_rerank

RERANKER_ENABLED=true
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_DEVICE=auto
RERANKER_USE_FP16=
RERANKER_BATCH_SIZE=1
RERANKER_MAX_LENGTH=512
RERANKER_CANDIDATE_K=10
RERANKER_OUTPUT_K=5
RERANKER_FALLBACK_MODE=error
RERANKER_CACHE_SIZE=128

QUERY_EMBEDDING_CACHE_ENABLED=true
QUERY_EMBEDDING_CACHE_SIZE=256
QUERY_EMBEDDING_CACHE_TTL_SECONDS=3600

# -----------------------------------------------------------------------------
# Hugging Face cache (optional locally; Docker Compose supplies /hf-cache).
# These values are also allowlisted for the retrieval MCP stdio child process.
# -----------------------------------------------------------------------------
HF_HOME=.cache/huggingface
HF_HUB_CACHE=
HUGGINGFACE_HUB_CACHE=
HF_HUB_OFFLINE=false

# -----------------------------------------------------------------------------
# Week 10 guardrail (fail-closed defaults are recommended)
# -----------------------------------------------------------------------------
GUARDRAIL_ENABLED=true
GUARDRAIL_CANONICAL_SOURCE_PATH=data/processed/labor_law_clauses.jsonl
GUARDRAIL_SEMANTIC_LOWER_THRESHOLD=0.35
GUARDRAIL_SEMANTIC_HIGH_THRESHOLD=0.75
GUARDRAIL_SEMANTIC_TIMEOUT_SECONDS=15
GUARDRAIL_SEMANTIC_BATCH_SIZE=4
GUARDRAIL_SEMANTIC_MAX_CONTEXTS=10
GUARDRAIL_SEMANTIC_MAX_TEXT_CHARACTERS=12000
GUARDRAIL_LLM_JUDGE_ENABLED=false
GUARDRAIL_JUDGE_TIMEOUT_SECONDS=10
GUARDRAIL_MAX_CLAIMS=12
GUARDRAIL_MAX_CITATIONS_PER_CLAIM=10
GUARDRAIL_FAIL_CLOSED=true

# -----------------------------------------------------------------------------
# Finite Agent policy (Compose overrides warm-up timeout values)
# Docker Compose raises the bounded timeouts for CPU model warm-up.
# -----------------------------------------------------------------------------
AGENT_MAX_INPUT_LENGTH=4000
AGENT_MAX_TOOL_CALLS=3
AGENT_TOOL_TIMEOUT_SECONDS=30
AGENT_WORKFLOW_TIMEOUT_SECONDS=90
AGENT_MAX_TRANSPORT_RETRIES=1
AGENT_STRUCTURED_OUTPUT_MAX_RETRIES=2
AGENT_MAX_RETRIEVAL_TOP_K=5
AGENT_TOOL_OUTPUT_MAX_CHARS=12000

# -----------------------------------------------------------------------------
# FastAPI, browser CORS, and local SQLite history
# Docker Compose overrides APP_DB_PATH to /runtime/app.sqlite3.
# -----------------------------------------------------------------------------
API_HOST=127.0.0.1
API_PORT=8000
APP_DB_PATH=data/runtime/app.sqlite3
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080
API_MAX_PAGE_SIZE=50
